# --- Database (leave DATABASE_URL empty to run in Temporary/in-memory mode) ---
DATABASE_URL=

# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Cloudinary (optional until M5) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
